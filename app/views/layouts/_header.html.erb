<header class="navbar navbar-fixed-top navbar-inverse">
    <div class="container">
    <%= link_to t("layout.sample_app"), root_path, id: "logo" %>
    <nav>
      <ul class="nav navbar-nav navbar-right">
        <li> <%= link_to t("layout.home"), root_path %> </li>
        <li> <%= link_to t("layout.help"), help_path %> </li>
        <% if logged_in? %>
          <li> <%= link_to t("layout.users"), '#' %> </li>
          <li class="dropdown">
            <a href="#" id="account" class="dropdown-toggle">
              Account <b class="caret"></b>
            </a>
            <ul id="dropdown-menu" class="dropdown-menu">
              <li> <%= link_to t("layout.profile"), current_user %> </li>
              <li> <%= link_to t("layout.settings"), '#' %> </li>
              <li class="divider"></li>
              <li>
                <%= link_to t("layout.logout"), logout_path, data: { "turbo-method": :delete } %>
              </li>
            </ul>
          </li>
        <% else %>
          <li> <%= link_to t("layout.login"), login_path %> </li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
